# Telegram
TELEGRAM_BOT_TOKEN=
# Optional HTTP/SOCKS proxy for api.telegram.org (e.g. http://127.0.0.1:10808)
TELEGRAM_PROXY=

# Groq LLM (فاز ۱ – پیشنهادی)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
USE_LLM=true

# OpenAI (اختیاری – فقط برای Chroma embeddings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Product CSV download URL (used if products_500.csv missing)
CSV_DOWNLOAD_URL=https://raw.githubusercontent.com/example/products_500.csv

# Follow-up intervals (seconds) – use short values for demo
FOLLOWUP_1H_SECONDS=3600
DISCOUNT_2D_SECONDS=172800
# Demo: FOLLOWUP_1H_SECONDS=60
# Demo: DISCOUNT_2D_SECONDS=120

# Demo simulation (no Telegram):
# python scripts/run_demo_simulation.py

# Vector store: keyword (offline, پیش‌فرض) | tfidf | chroma | auto
VECTOR_STORE_BACKEND=keyword

# RAG
RAG_TOP_K=10

# Retry
MAX_RETRIES=3
RETRY_DELAY=1.0

# Logging
LOG_LEVEL=INFO
