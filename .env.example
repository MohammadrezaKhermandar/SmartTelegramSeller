# LLM provider: openrouter | xai | groq
LLM_PROVIDER=openrouter
USE_LLM=true

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=SINWAY Sales Assistant

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: leave empty when no proxy is needed
TELEGRAM_PROXY=http://127.0.0.1:10808

# Data
PRODUCTS_CSV_PATH=products_500.csv
VECTOR_DB_PATH=.data/chroma
# keyword = offline in-memory hash (stable on Windows); chroma = ChromaDB
VECTOR_STORE_BACKEND=keyword
MEMORY_DB_PATH=.data/memory.sqlite

# Embeddings: hash (offline, default) | onnx (MiniLM, downloads a model once)
EMBEDDING_MODE=hash

# Runtime
LOG_LEVEL=INFO

# Follow-up timing (seconds) — shrink for demos, e.g. 60 and 180
FOLLOWUP_IDLE_SECONDS=3600
FOLLOWUP_PURCHASE_SECONDS=172800
FOLLOWUP_CHECK_INTERVAL=60
DISCOUNT_CODE=SALE10

# Retry policy
MAX_RETRIES=3
LLM_MAX_TOKENS=800
